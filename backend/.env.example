# Pathfinding Visualization Platform
APP_NAME=Pathfinding Visualization Platform
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://pathfinder:pathfinder_password@localhost:5432/pathfinding
DATABASE_SYNC_URL=postgresql://pathfinder:pathfinder_password@localhost:5432/pathfinding


# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Graph settings
DEFAULT_GRAPH_RADIUS_KM=10.0
FLOYD_WARSHALL_NODE_LIMIT=1000
GRAPH_CACHE_DIR=./data/graphs

# OSM ingestion (required for real-street routing)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
